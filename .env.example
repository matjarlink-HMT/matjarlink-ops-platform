# ── MatjarLink Ops Platform — Environment ──────────────────────────────
# انسخ هذا الملف إلى .env واملأ القيم. كل مفتاح فارغ = يبقى القسم بالوضع التجريبي.
# MODE=mock  → بيانات تجريبية (يعمل فوراً بلا مفاتيح)
# MODE=live  → يسحب البيانات الحقيقية من المنصات المربوطة
MODE=mock
PORT=8080

# اختياري: كلمة مرور بسيطة لحماية اللوحة (Basic gate). اتركها فارغة لتعطيلها.
DASHBOARD_PASSWORD=

# ── Meta Graph API (Instagram + Facebook) ─────────────────────────────
# من Meta for Developers → تطبيقك → أضف "Instagram Graph API" و "Messenger"
# صلاحيات مطلوبة: instagram_basic, instagram_manage_comments,
# instagram_manage_messages, pages_manage_metadata, pages_messaging,
# pages_read_engagement, pages_show_list
META_ACCESS_TOKEN=          # توكن صفحة طويل الأمد (Long-lived Page token)
META_IG_USER_ID=17841449202353128   # معرّف حساب إنستغرام الاحترافي (@matjarlink)
META_PAGE_ID=1247632705095985       # معرّف صفحة فيسبوك (MatjarLink)
META_GRAPH_VERSION=v19.0

# ── WhatsApp Cloud API ────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=matjarlink_verify   # لاعتماد الـWebhook

# ── Windsor.ai (تحليلات الأداء) ───────────────────────────────────────
# من windsor.ai → API → انسخ المفتاح. يجمع بيانات IG/FB organic + Ads.
WINDSOR_API_KEY=
WINDSOR_FIELDS=source,date,followers,reach,impressions,engagement,clicks

# ── ClickUp (اختياري: نظام المهام) ───────────────────────────────────
CLICKUP_TOKEN=
CLICKUP_LIST_ID=
